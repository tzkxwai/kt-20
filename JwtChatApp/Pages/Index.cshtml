@page
@model IndexModel
@{
    ViewData["Title"] = "Чат";
}

<h1>Чат с JWT</h1>

<div class="row">
    <div class="panel">
        <h2>Регистрация</h2>
        <form id="formRegister" autocomplete="off">
            <label for="regEmail">Email</label>
            <input type="email" id="regEmail" required />
            <label for="regPassword">Пароль (мин. 4 символа)</label>
            <input type="password" id="regPassword" required minlength="4" />
            <button type="submit">Создать аккаунт</button>
        </form>
        <div id="regStatus" class="status"></div>
    </div>
    <div class="panel">
        <h2>Вход</h2>
        <form id="formLogin" autocomplete="on">
            <label for="loginEmail">Email</label>
            <input type="email" id="loginEmail" required />
            <label for="loginPassword">Пароль</label>
            <input type="password" id="loginPassword" required />
            <button type="submit">Войти</button>
        </form>
        <div id="loginStatus" class="status"></div>
    </div>
</div>

<div id="chatPanel" class="panel hidden">
    <div class="chat-head">
        <h2 style="margin:0;">Сообщения</h2>
        <span class="chat-user" id="userLabel"></span>
        <button type="button" class="secondary" id="btnLogout">Выйти</button>
    </div>
    <div id="messages" aria-live="polite"></div>
    <form id="formSend" class="chat-input-row">
        <input type="text" id="messageText" placeholder="Текст сообщения…" maxlength="500" autocomplete="off" />
        <button type="submit">Отправить</button>
    </form>
    <p class="hint">Подключение к SignalR выполняется с передачей JWT — без токена хаб недоступен.</p>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
    <script src="~/js/chat.js" asp-append-version="true"></script>
}
